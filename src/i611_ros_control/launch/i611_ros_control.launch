<launch>
  <arg name="robot_ip" default="192.168.0.23"/>
  <arg name="robot_port" default="4416"/>
  <arg name="command_method" default="move_joint_nores"/>

  <node pkg="i611_ros_control" type="i611_hw_node" name="i611_hw_node" output="screen">
    <param name="robot_ip" value="$(arg robot_ip)"/>
    <param name="robot_port" value="$(arg robot_port)"/>
    <param name="command_method" value="$(arg command_method)"/>
  </node>

  <rosparam file="$(find i611_ros_control)/config/controllers.yaml" command="load"/>

  <node pkg="controller_manager" type="spawner" name="controller_spawner"
      args="joint_state_controller arm_controller"
      output="screen"
      respawn="false"
  />

</launch>
