<launch>

  <!-- OGM -->
  <node pkg="i611_ros" type="gridmap_node.py" name="gridmap_node" output="screen">
    <param name="sensor_topic" value="/camera/depth/color/points" />
    <param name="map_frame" value="map" />
    <param name="use_rgb" value="true" />
    <param name="gpu_id" value="0" />

    <param name="x_min" value="-0.8" />
    <param name="x_max" value="0.8" />
    <param name="y_min" value="-0.8" />
    <param name="y_max" value="0.8" />
    <param name="z_min" value="0.0" />
    <param name="z_max" value="1.6" />
    <param name="resolution" value="0.01" />

    <param name="p_init" value="0.5" />
    <param name="p_free" value="0.4" />
    <param name="p_occ" value="0.7" />
    <param name="vis_threshold" value="0.75" />
  </node>

  <!-- Initial Pose of RTAB-Map -->
  <node pkg="tf2_ros" type="static_transform_publisher"
    name="map_to_odom"
    args="-0.75 0 0.45 0 0 0 map odom" />

  <!-- RealSense -->
  <include file="$(find realsense2_camera)/launch/rs_aligned_depth.launch">
    <arg name="enable_pointcloud" value="true"/>
  </include>

  <!-- RTAB-Map -->
  <include file="$(find rtabmap_ros)/launch/rtabmap.launch">

    <arg name="publish_tf_map" value="false"/>
    <arg name="publish_tf_odom" value="true"/>

    <!-- DB を毎回削除 -->
    <arg name="rtabmap_args" value="--delete_db_on_start"/>

    <!-- トピック指定 -->
    <arg name="rgb_topic" value="/camera/color/image_raw"/>
    <arg name="depth_topic" value="/camera/aligned_depth_to_color/image_raw"/>
    <arg name="camera_info_topic" value="/camera/color/camera_info"/>

    <!-- Localization-only mode -->
    <!-- <arg name="localization"            value="true"/>
    <arg name="initial_pose"            value="-1 0 0.5 0 0 0"/>    -->
    <arg name="visual_odometry"          value="true"/>
    <arg name="icp_odometry"             value="false"/>
    <!-- <arg name="subscribe_scan_cloud"    value="true"/>
    <arg name="scan_cloud_topic"        value="/scan_cloud"/> -->

    <!-- TF -->
    <arg name="frame_id" value="camera_link"/>
    <arg name="odom_frame_id" value="odom"/>
    <arg name="map_frame_id" value="map"/>

  </include>

  <!-- ===== RViz ===== -->
  <node pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find i611_ros)/config/rviz_config_rosbag.rviz"
        required="false"/>

</launch>
